{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    ":dependencyDashboard",
    ":disableRateLimiting",
  ],
  timezone: "America/New_York",
  labels: ["dependencies"],
  // The renovate-nix-hash workflow refreshes Nix digests on Renovate branches;
  // ignore its commits so Renovate keeps rebasing/managing those branches.
  gitIgnoredAuthors: ["renovate-nix-hash@users.noreply.github.com"],
  enabledManagers: ["custom.regex", "github-actions", "nix"],
  // Daily run before 5am Eastern so dependency drift is caught quickly and
  // auto-merged PRs land the same day their checks pass.
  schedule: ["before 5am"],
  prConcurrentLimit: 5,
  branchConcurrentLimit: 5,
  rebaseWhen: "behind-base-branch",
  minimumReleaseAge: "3 days",
  // Automerge by default for non-major updates after required CI checks pass.
  // Use GitHub native PR auto-merge explicitly: branch automerge cannot satisfy
  // the main ruleset's required status checks, but PR auto-merge can queue the
  // squash merge and let GitHub land it once all checks pass.
  automerge: true,
  automergeType: "pr",
  platformAutomerge: true,
  automergeStrategy: "squash",
  nix: {
    enabled: true,
  },
  customManagers: [
    {
      customType: "regex",
      description: "Update comment-annotated Nix version fields",
      managerFilePatterns: ["/(^|/)nix/(lib|modules|packages)/.*\\.nix$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: packageName=(?<packageName>[^\\s]+))?(?: versioning=(?<versioning>[^\\s]+))?\\s+version\\s*=\\s*\"(?<currentValue>[^\"]+)\";",
      ],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
    {
      customType: "regex",
      description: "Update comment-annotated npm package wrappers",
      managerFilePatterns: ["/(^|/)nix/packages/.*\\.nix$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\s+.*?@(?<currentValue>[^\"\\s]+)",
      ],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}npm{{/if}}",
    },
    {
      customType: "regex",
      description: "Track comment-annotated VS Code marketplace versions",
      managerFilePatterns: ["/(^|/)nix/modules/home/ide/vscode\\.nix$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: packageName=(?<packageName>[^\\s]+))?(?: versioning=(?<versioning>[^\\s]+))?\\s+version\\s*=\\s*\"(?<currentValue>[^\"]+)\";",
      ],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
  ],
  lockFileMaintenance: {
    enabled: true,
    dependencyDashboardApproval: false,
    automerge: true,
    automergeType: "pr",
    platformAutomerge: true,
    automergeStrategy: "squash",
    schedule: ["before 5am"],
  },
  vulnerabilityAlerts: {
    enabled: true,
    labels: ["security"],
  },
  packageRules: [
    {
      description: "Keep GitHub Actions updates small and automatically merged after CI",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["digest", "patch", "minor"],
      groupName: "github-actions",
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      automergeStrategy: "squash",
    },
    {
      description: "Automerge daily flake lock maintenance after checks pass",
      matchManagers: ["nix"],
      matchUpdateTypes: ["lockFileMaintenance", "digest"],
      groupName: "flake lock maintenance",
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      automergeStrategy: "squash",
    },
    {
      description: "Group core flake inputs in the daily update window",
      matchManagers: ["nix"],
      matchPackageNames: [
        "nixpkgs",
        "unstable",
        "home-manager",
        "darwin",
        "snowfall-lib",
      ],
      groupName: "core flake inputs",
      minimumReleaseAge: "3 days",
      schedule: ["before 5am"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      automergeStrategy: "squash",
    },
    {
      description: "Automerge non-major flake updates after CI and security checks pass",
      matchManagers: ["nix"],
      matchUpdateTypes: ["minor", "patch"],
      matchCurrentVersion: "!/^0/",
      minimumReleaseAge: "3 days",
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      automergeStrategy: "squash",
    },
    {
      description: "Require manual review for majors and unstable pre-1.0 bumps",
      matchUpdateTypes: ["major"],
      dependencyDashboardApproval: true,
      automerge: false,
    },
    {
      description: "Require approval for regex-managed custom source bumps",
      matchManagers: ["custom.regex"],
      dependencyDashboardApproval: true,
      automerge: false,
    },
    {
      // Helium ships per-platform binaries; bumping the version leaves four
      // stale SRI digests behind. The hosted Renovate App cannot run Nix, so the
      // `renovate-nix-hash` workflow refreshes the digests on the branch; this
      // rule just lets the bump bypass approval and automerge once CI is green.
      description: "Auto-update Helium (digests refreshed by the renovate-nix-hash workflow)",
      matchManagers: ["custom.regex"],
      matchDepNames: ["helium"],
      dependencyDashboardApproval: false,
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      automergeStrategy: "squash",
    },
  ],
}
