{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    ":dependencyDashboard",
    ":pinGitHubActionDigests",
    ":disableRateLimiting",
  ],
  timezone: "America/New_York",
  labels: ["dependencies"],
  enabledManagers: ["custom.regex", "github-actions", "nix"],
  schedule: ["before 5am on Monday"],
  prConcurrentLimit: 5,
  branchConcurrentLimit: 5,
  rebaseWhen: "behind-base-branch",
  minimumReleaseAge: "3 days",
  nix: {
    enabled: true,
  },
  customManagers: [
    {
      customType: "regex",
      description: "Update comment-annotated Nix version fields",
      managerFilePatterns: ["/(^|/)nix/(lib|modules|packages)/.*\\.nix$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: packageName=(?<packageName>[^\\s]+))?(?: versioning=(?<versioning>[^\\s]+))?\\s+version\\s*=\\s*\"(?<currentValue>[^\"]+)\";",
      ],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
    {
      customType: "regex",
      description: "Update comment-annotated npm package wrappers",
      managerFilePatterns: ["/(^|/)nix/packages/.*\\.nix$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\s+.*?@(?<currentValue>[^\"\\s]+)",
      ],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}npm{{/if}}",
    },
    {
      customType: "regex",
      description: "Track comment-annotated VS Code marketplace versions",
      managerFilePatterns: ["/(^|/)nix/modules/home/ide/vscode\\.nix$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: packageName=(?<packageName>[^\\s]+))?(?: versioning=(?<versioning>[^\\s]+))?\\s+version\\s*=\\s*\"(?<currentValue>[^\"]+)\";",
      ],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
  ],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    platformAutomerge: true,
    schedule: ["before 5am on Monday"],
  },
  vulnerabilityAlerts: {
    enabled: true,
    labels: ["security"],
  },
  packageRules: [
    {
      description: "Keep GitHub Actions updates small and automatically merged after CI",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["digest", "patch", "minor"],
      groupName: "github-actions",
      automerge: true,
      platformAutomerge: true,
      automergeStrategy: "squash",
    },
    {
      description: "Automerge weekly flake lock maintenance after checks pass",
      matchManagers: ["nix"],
      matchUpdateTypes: ["lockFileMaintenance", "digest"],
      groupName: "flake lock maintenance",
      automerge: true,
      platformAutomerge: true,
      automergeStrategy: "squash",
    },
    {
      description: "Group core flake inputs and keep unstable channels from churning daily",
      matchManagers: ["nix"],
      matchPackageNames: [
        "nixpkgs",
        "unstable",
        "home-manager",
        "darwin",
        "snowfall-lib",
      ],
      groupName: "core flake inputs",
      minimumReleaseAge: "3 days",
      schedule: ["before 5am on Monday"],
    },
    {
      description: "Automerge non-major flake updates after CI and security checks pass",
      matchManagers: ["nix"],
      matchUpdateTypes: ["minor", "patch"],
      matchCurrentVersion: "!/^0/",
      minimumReleaseAge: "3 days",
      automerge: true,
      platformAutomerge: true,
      automergeStrategy: "squash",
    },
    {
      description: "Require manual review for majors and unstable pre-1.0 bumps",
      matchUpdateTypes: ["major"],
      dependencyDashboardApproval: true,
      automerge: false,
    },
    {
      description: "Require approval for regex-managed custom source bumps",
      matchManagers: ["custom.regex"],
      dependencyDashboardApproval: true,
      automerge: false,
    },
  ],
}
