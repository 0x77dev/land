{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".cursor/rules/*.mdc", "*.md", "*.nix", "nix/**/*.nix"],
  "disabled_providers": ["opencode"],
  "plugin": ["@simonwjackson/opencode-direnv", "oh-my-openagent"],
  "default_agent": "hephaestus",
  "snapshot": false,
  "share": "disabled",
  "experimental": {
    "openTelemetry": false
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "provider": {
    "furnace": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Furnace Cluster",
      "options": {
        "apiKey": "{env:FURNACE_GLM_API_KEY}",
        "baseURL": "{env:FURNACE_GLM_ENDPOINT}"
      },
      "models": {
        "zai-org/GLM-5": {
          "name": "GLM 5",
          "limit": { "context": 262000, "output": 64000 },
          "variants": {
            "instant": {
              "chat_template_kwargs": { "thinking": false }
            },
            "thinking": {
              "include": ["reasoning"]
            }
          }
        }
      }
    }
  },
  "model": "openai/gpt-5.5",
  "small_model": "furnace/zai-org/GLM-5"
}
