{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".cursor/rules/*.mdc", "*.md", "*.nix", "nix/**/*.nix"],
  "disabled_providers": ["opencode"],
  "plugin": ["@simonwjackson/opencode-direnv", "oh-my-opencode"],
  "snapshot": false,
  "provider": {
    "vercel": {
      "models": {
        "anthropic/claude-opus-4.6": {
          "limit": { "context": 1000000, "output": 128000 },
          "options": {
            "order": ["anthropic", "vertex", "bedrock"],
            "zeroDataRetention": true,
            "caching": "auto"
          }
        },
        "anthropic/claude-sonnet-4.6": {
          "limit": { "context": 1000000, "output": 128000 },
          "options": {
            "order": ["anthropic", "vertex", "bedrock"],
            "zeroDataRetention": true,
            "caching": "auto"
          }
        },
        "anthropic/claude-haiku-4.5": {
          "limit": { "context": 200000, "output": 64000 },
          "options": {
            "order": ["anthropic", "vertex"],
            "zeroDataRetention": true
          }
        },
        "google/gemini-3.1-pro-preview": {
          "limit": { "context": 1000000, "output": 64000 },
          "options": {
            "order": ["vertex", "google"],
            "zeroDataRetention": true
          }
        },
        "google/gemini-3-flash": {
          "limit": { "context": 1000000, "output": 65000 },
          "options": {
            "order": ["vertex", "google"],
            "zeroDataRetention": true
          }
        },
        "openai/gpt-5.4": {
          "options": {
            "order": ["openai"],
            "zeroDataRetention": true,
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "textVerbosity": "low",
            "include": ["reasoning.encrypted_content"]
          }
        },
        "openai/gpt-5.4-mini": {
          "options": {
            "order": ["openai"],
            "zeroDataRetention": true,
            "reasoningEffort": "low",
            "reasoningSummary": "auto",
            "textVerbosity": "low",
            "include": ["reasoning.encrypted_content"]
          }
        },
        "openai/gpt-5.3-codex": {
          "options": {
            "order": ["openai"],
            "zeroDataRetention": true,
            "reasoningEffort": "medium",
            "reasoningSummary": "auto",
            "textVerbosity": "medium",
            "include": ["reasoning.encrypted_content"]
          }
        }
      }
    },
    "furnace": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Furnace Cluster",
      "options": {
        "apiKey": "{env:FURNACE_GLM_API_KEY}",
        "baseURL": "{env:FURNACE_GLM_ENDPOINT}"
      },
      "models": {
        "zai-org/GLM-5": {
          "name": "GLM 5",
          "limit": { "context": 262000, "output": 64000 },
          "variants": {
            "instant": {
              "chat_template_kwargs": { "thinking": false }
            },
            "thinking": {
              "include": ["reasoning"]
            }
          }
        }
      }
    }
  },
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini"
}
