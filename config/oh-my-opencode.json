{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "default_run_agent": "hephaestus",
  "new_task_system_enabled": true,
  "agents": {
    "hephaestus": {
      "prompt_append": "Default to strategic planning before action: identify the objective, freedom of approach, available tools, and cheapest sufficient delegation path. Prefer category defaults over per-agent model overrides, and escalate only when the task genuinely needs it."
    }
  },
  "categories": {
    "quick": { "model": "furnace/zai-org/GLM-5", "variant": "instant" },
    "unspecified-low": { "model": "furnace/zai-org/GLM-5", "variant": "instant" },
    "unspecified-medium": { "model": "furnace/zai-org/GLM-5", "variant": "thinking" },
    "unspecified-high": { "model": "openai/gpt-5.5", "variant": "xhigh" },
    "visual-engineering": { "model": "openai/gpt-5.5", "variant": "xhigh" },
    "ultrabrain": { "model": "openai/gpt-5.5", "variant": "xhigh" },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [{ "model": "furnace/zai-org/GLM-5", "variant": "thinking" }]
    },
    "artistry": { "model": "openai/gpt-5.5", "variant": "xhigh" },
    "writing": { "model": "furnace/zai-org/GLM-5", "variant": "instant" }
  },
  "disabled_mcps": ["websearch", "context7", "grep_app"],
  "disabled_hooks": []
}
